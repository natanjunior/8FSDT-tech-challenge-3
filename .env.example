# .env.example
# Copie para .env.local e preencha os valores

# URL do backend (Fase 2) — sem barra final
NEXT_PUBLIC_API_URL=http://localhost:3030

# Secret JWT — DEVE ser o mesmo valor usado no backend da Fase 2
# Usado apenas server-side para decodificar o token sem chamada extra ao backend
JWT_SECRET=seu_jwt_secret_aqui
